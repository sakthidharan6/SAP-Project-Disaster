projection;
strict ( 2 );
use draft;

define behavior for ZCIT_CDSTR_22IT alias Disaster
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Resource { create; with draft; }
}

define behavior for ZCIT_CRESC_22IT alias Resource
{
  use update;
  use delete;

  use association _Disaster { with draft; }
}